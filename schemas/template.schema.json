{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Label Template",
  "type": "object",
  "required": ["id", "name", "description", "format", "fields"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "format": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "labels_per_sheet", "paper_size", "label_size"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "sheet" },
            "labels_per_sheet": { "type": "integer", "minimum": 1 },
            "paper_size": { "type": "string", "minLength": 1 },
            "label_size": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "required": ["type", "width_mm"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "continuous" },
            "width_mm": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      ]
    },
    "options": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["values", "default"],
        "additionalProperties": false,
        "properties": {
          "values": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "default": { "type": "string" }
        }
      }
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["string"] },
          "max_length": { "type": "integer", "minimum": 1 },
          "multiline": { "type": "boolean" }
        }
      }
    }
  }
}
